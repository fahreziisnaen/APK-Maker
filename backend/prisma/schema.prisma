generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Build {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // User-supplied config
  appName       String
  packageName   String
  websiteUrl    String
  themeColor    String   @default("#2563EB")
  userAgent     String?

  // Feature flags
  enablePushNotifications Boolean @default(false)
  enablePullToRefresh     Boolean @default(true)
  enableOfflineFallback   Boolean @default(false)
  buildAab                Boolean @default(false)

  // Asset paths (relative to storage dir)
  iconPath        String?
  splashPath      String?

  // Build lifecycle — stored as String because SQLite has no enum type
  // Valid values: PENDING | QUEUED | BUILDING | SUCCESS | FAILED
  status          String   @default("PENDING")
  jobId           String?
  logs            String?     // newline-separated log lines
  errorMessage    String?
  outputPath      String?     // relative path to final APK/AAB
  outputSize      Int?        // bytes

  // Optional user tracking
  userEmail       String?
  ipAddress       String?
}
